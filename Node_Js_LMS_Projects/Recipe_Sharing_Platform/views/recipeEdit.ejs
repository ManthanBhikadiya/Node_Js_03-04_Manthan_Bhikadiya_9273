<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recipe App - Edit Recipe</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include("navbar") %>

    <div class="container">
        <h2>Edit Recipe</h2>
        <form method="POST" action="/recipes/<%= recipe._id %>?_method=PUT" class="recipe-form-container">
            <div class="recipe-form-group">
                <label for="title">Title:</label>
                <input type="text" id="title" name="title" value="<%= recipe.title %>" required>
            </div>
            
            <div class="recipe-form-group">
                <label for="image">Image URL (optional):</label>
                <input type="url" id="image" name="image" value="<%= recipe.image || '' %>" placeholder="Image URL">
                <% if (recipe.image) { %>
                    <div class="recipe-image-preview">
                        <img src="<%= recipe.image %>" alt="Current Image Preview">
                    </div>
                <% } %>
            </div>
            
            <div class="recipe-form-group">
                <label for="ingredients">Ingredients:</label>
                <textarea id="ingredients" name="ingredients" required><%= recipe.ingredients %></textarea>
            </div>
            
            <div class="recipe-form-group">
                <label for="steps">Steps:</label>
                <textarea id="steps" name="steps" required><%= recipe.steps %></textarea>
            </div>
            
            <button type="submit" class="btn">Update Recipe</button>
            <a href="/recipes" class="btn" style="background: #6c757d;">Cancel</a>
        </form>
    </div>
</body>
</html>